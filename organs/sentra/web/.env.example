# Sentra — Environment Variables
# Copy this file to .env.local and fill in values for your environment.
# All variables prefixed VITE_ are exposed to the browser bundle.

# ── Feature Flags ─────────────────────────────────────────────────────────────

# Enable the Predictive Cortex section in the sidebar
VITE_PREDICTIVE_CORTEX_ENABLED=true

# ── Sentra Doctrine ───────────────────────────────────────────────────────────

# Tenant identifier — used as the tenant_id in all store records
VITE_SENTRA_TENANT_ID=tenant-demo

# Override the default doctrine denial message shown in the Safety Gate UI
# VITE_SENTRA_DENIAL_MESSAGE="..."

# ── Integration Adapter Stubs ─────────────────────────────────────────────────
# These are stub adapters. No real outbound API calls are made.
# Set to 'configured' to show the adapter as connected in the Integrations Hub.
VITE_ADAPTER_MDE_STATUS=configured
VITE_ADAPTER_CROWDSTRIKE_STATUS=not_configured
VITE_ADAPTER_SENTINEL_STATUS=configured
VITE_ADAPTER_SPLUNK_STATUS=not_configured
VITE_ADAPTER_ENTRA_STATUS=configured
VITE_ADAPTER_AWS_STATUS=configured
VITE_ADAPTER_AZURE_STATUS=not_configured
VITE_ADAPTER_GITHUB_STATUS=configured
VITE_ADAPTER_CLOUDFLARE_STATUS=not_configured
VITE_ADAPTER_PAGERDUTY_STATUS=configured
VITE_ADAPTER_JIRA_STATUS=not_configured
VITE_ADAPTER_SERVICENOW_STATUS=not_configured
VITE_ADAPTER_GCP_STATUS=not_configured
VITE_ADAPTER_DRAGOS_STATUS=not_configured
VITE_ADAPTER_TENABLE_STATUS=configured
VITE_ADAPTER_PROOFPOINT_STATUS=not_configured

# ── A11oy Orchestration ───────────────────────────────────────────────────────
# Base URL of the A11oy orchestration layer (used for cross-app deep links)
VITE_A11OY_BASE_URL=/

# ── Build ─────────────────────────────────────────────────────────────────────
# Set by Replit automatically — do not change
# PORT=4099
