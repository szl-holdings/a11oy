# Amaru sidecar — environment configuration
# Copy to .env and adjust. Every variable the runtime reads is documented here.
# All have safe defaults; the service boots with an empty .env.

# --- Server ------------------------------------------------------------------
# TCP port the FastAPI app binds to. Default 6810 (standalone),
# 7860 on Hugging Face Spaces via deploy/huggingface/serve.py.
PORT=6810

# --- Build identity (surfaced at /healthz) -----------------------------------
# Git commit SHA of the running build. Set at build time (Docker ARG/ENV).
# If unset, the runtime falls back to GIT_SHA / SOURCE_COMMIT / GIT_COMMIT,
# then `git rev-parse HEAD`, then "unknown".
AMARU_GIT_SHA=

# --- Structured logging ------------------------------------------------------
# Root log level: DEBUG | INFO | WARNING | ERROR. Default INFO.
AMARU_LOG_LEVEL=INFO
# Log output format: "json" (default, one JSON object per line) or "text".
AMARU_LOG_FORMAT=json

# --- OpenTelemetry tracing (optional) ----------------------------------------
# "1"/"true" to emit spans on /scheduler/tick and /receipts. Requires the
# `otel` extra (pip install -e ".[otel]"). Default off → no-op spans.
AMARU_OTEL_ENABLED=0
# service.name resource attribute for emitted spans. Default "amaru".
AMARU_SERVICE_NAME=amaru
# Standard OTLP exporter endpoint, honored by the opentelemetry SDK when the
# `otel` extra is installed and AMARU_OTEL_ENABLED=1.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Yawar bus (Prism Bus HTTP publish surface) ------------------------------
# Best-effort receipt publication target. Chakra evaluation never fails if the
# bus is unreachable; failures are surfaced on receipt metadata and counters.
AMARU_YAWAR_BUS_URL=http://localhost:8080/api/prism-bus/publish
# Bearer token for the bus, if it requires auth. Empty = unauthenticated.
AMARU_YAWAR_BUS_TOKEN=
# Domain tag attached to published envelopes. Default "amaru".
AMARU_YAWAR_BUS_DOMAIN=amaru
