{
  "name": "@szl-holdings/rosie-widget",
  "version": "0.1.0",
  "description": "Ambient operator widget — floating launcher, Cmd-K palette, and execute-with-confirm — embedded in a11oy, amaru, sentra, vessels, and rosie.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Stephen P. Lutar",
  "repository": "github:szl-holdings/rosie",
  "main": "./dist/rosie-widget.umd.cjs",
  "module": "./dist/rosie-widget.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rosie-widget.js",
      "require": "./dist/rosie-widget.umd.cjs"
    }
  },
  "files": ["dist", "src", "README.md", "docs"],
  "sideEffects": ["./dist/rosie-widget.js", "./dist/rosie-widget.umd.cjs"],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "size": "size-limit",
    "storybook": "storybook dev -p 6007 --no-open",
    "build-storybook": "storybook build -o storybook-static"
  },
  "dependencies": {
    "lit": "^3.1.0"
  },
  "peerDependencies": {
    "@szl-holdings/a11oy-receipt-substrate": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@szl-holdings/a11oy-receipt-substrate": {
      "optional": true
    }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.0",
    "@storybook/web-components-vite": "^8.4.0",
    "size-limit": "^11.1.0",
    "storybook": "^8.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "size-limit": [
    {
      "name": "rosie-widget (ESM, gzip)",
      "path": "dist/rosie-widget.js",
      "limit": "30 kB"
    }
  ]
}
