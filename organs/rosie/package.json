{
  "name": "rosie",
  "version": "0.0.1",
  "private": true,
  "description": "operator console — Khipu Receipt DAG with QEC-Governed Ingress",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "rosie-server": "./src/server/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:fuzz": "vitest run --config vitest.fuzz.config.ts",
    "build": "tsc --noEmit",
    "lint": "eslint --ext .ts src/ tests/ test/",
    "lint:fix": "eslint --ext .ts --fix src/ tests/ test/",
    "server": "node --experimental-strip-types src/server/index.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "fast-check": "^3.23.2",
    "supertest": "^7.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
