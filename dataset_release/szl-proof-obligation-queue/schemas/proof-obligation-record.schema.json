{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a-11-oy.com/schemas/szl-proof-obligation-record-v1.json",
  "title": "SZL proof-obligation queue record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "queue_id",
    "record_id",
    "formula_id",
    "formula_namespace",
    "canonical_name",
    "claim_sha256",
    "resolved_status",
    "obligation_state",
    "queue_membership",
    "required_actions",
    "status_reasons",
    "lean_reference",
    "namespace_collision",
    "proof_transfer_allowed",
    "split",
    "training_eligible",
    "receipt_scope",
    "queue_record_sha256"
  ],
  "properties": {
    "schema_version": {"const": "szl.proof-obligation-record.v1"},
    "queue_id": {"type": "string", "pattern": "^proof-obligation:.+$"},
    "record_id": {"type": "string", "minLength": 1},
    "formula_id": {"type": "string", "minLength": 1},
    "formula_namespace": {"type": "string", "minLength": 1},
    "canonical_name": {"type": "string", "minLength": 1},
    "claim_sha256": {"$ref": "#/$defs/sha256"},
    "resolved_status": {
      "enum": ["KERNEL_ACCEPTED", "CONDITIONAL", "OPEN", "REFUTED"]
    },
    "obligation_state": {
      "enum": [
        "SATISFIED_LOCAL_ITEM_BINDING",
        "ACTION_REQUIRED_CONDITIONAL",
        "ACTION_REQUIRED_OPEN",
        "CONFLICT_RECORDED_REFUTED"
      ]
    },
    "queue_membership": {"enum": ["ACTION_REQUIRED", "AUDIT_ONLY"]},
    "required_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "status_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "lean_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "observed"],
      "properties": {
        "identifier": {"type": ["string", "null"]},
        "observed": {"type": "boolean"}
      }
    },
    "namespace_collision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation", "other_namespace", "other_name"],
      "properties": {
        "relation": {"type": ["string", "null"]},
        "other_namespace": {"type": ["string", "null"]},
        "other_name": {"type": ["string", "null"]}
      }
    },
    "proof_transfer_allowed": {"const": false},
    "split": {"const": "HOLDOUT"},
    "training_eligible": {"const": false},
    "receipt_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_artifact_receipt_sha256",
        "source_crosswalk_receipt_sha256",
        "source_record_receipt_sha256"
      ],
      "properties": {
        "source_artifact_receipt_sha256": {"$ref": "#/$defs/sha256"},
        "source_crosswalk_receipt_sha256": {"$ref": "#/$defs/sha256"},
        "source_record_receipt_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "queue_record_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
