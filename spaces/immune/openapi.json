{
  "openapi": "3.1.0",
  "info": {
    "title": "SZL Immune API",
    "version": "0.1.0",
    "description": "A fail-closed inspection and tool-authorization boundary. Model-backed classification and signed authorization remain unavailable until their exact runtime evidence exists."
  },
  "servers": [{ "url": "/" }],
  "tags": [{ "name": "immune" }],
  "paths": {
    "/api/immune/v1/status": {
      "get": {
        "operationId": "getImmuneStatus",
        "tags": ["immune"],
        "responses": {
          "200": {
            "description": "Current measured and declared capability state",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusResponse" } } }
          }
        }
      }
    },
    "/api/immune/v1/inspect": {
      "post": {
        "operationId": "inspectImmuneInput",
        "tags": ["immune"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/InspectRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Deterministic inspection verdict with optional signed receipt",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DecisionResponse" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "413": { "$ref": "#/components/responses/TooLarge" }
        }
      }
    },
    "/api/immune/v1/tool-authorize": {
      "post": {
        "operationId": "authorizeImmuneTool",
        "tags": ["immune"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ToolAuthorizeRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Authorization verdict; ALLOW requires a qualified classifier and signed receipt",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DecisionResponse" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "413": { "$ref": "#/components/responses/TooLarge" }
        }
      }
    },
    "/api/immune/v1/receipts/{receiptId}": {
      "get": {
        "operationId": "getImmuneReceipt",
        "tags": ["immune"],
        "parameters": [{ "name": "receiptId", "in": "path", "required": true, "schema": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }],
        "responses": {
          "200": {
            "description": "Stored DSSE envelope and decoded public payload",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReceiptResponse" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/immune/v1/tripwires": {
      "get": {
        "operationId": "getImmuneTripwires",
        "tags": ["immune"],
        "responses": {
          "200": {
            "description": "Tripwire implementation and evaluation state",
            "content": { "application/json": { "schema": { "type": "object", "required": ["schemaVersion", "tripwires"], "properties": { "schemaVersion": { "const": "szl.immune.tripwires/v1" }, "tripwires": { "type": "array", "items": { "$ref": "#/components/schemas/Tripwire" } } } } } }
          }
        }
      }
    },
    "/api/immune/v1/session/state": {
      "get": {
        "operationId": "getImmuneSessionState",
        "tags": ["immune"],
        "responses": {
          "200": { "description": "Session-scoped public demo state", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SessionState" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "post": {
        "operationId": "updateImmuneSessionState",
        "tags": ["immune"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "additionalProperties": false, "properties": { "strictMode": { "type": "boolean" } } } } } },
        "responses": {
          "200": { "description": "Updated session-scoped state", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SessionState" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": { "description": "Request was invalid", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "TooLarge": { "description": "Request exceeded the bounded input size", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
      "NotFound": { "description": "Receipt was not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
    },
    "schemas": {
      "InspectRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content", "source"],
        "properties": {
          "sessionId": { "type": "string" },
          "content": { "type": "string", "maxLength": 65536 },
          "source": { "type": "object", "additionalProperties": false, "required": ["kind", "trust"], "properties": { "kind": { "type": "string", "enum": ["user", "tool_response", "retrieval", "memory", "system"] }, "trust": { "type": "string", "enum": ["trusted", "untrusted", "unknown"] } } },
          "actor": { "type": "object", "additionalProperties": false, "properties": { "id": { "type": "string" }, "role": { "type": "string" }, "scopes": { "type": "array", "items": { "type": "string" }, "maxItems": 64 } } }
        }
      },
      "ToolAuthorizeRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/InspectRequest" },
          { "type": "object", "required": ["tool"], "properties": { "tool": { "type": "object", "additionalProperties": false, "required": ["name", "capability", "arguments"], "properties": { "name": { "type": "string" }, "capability": { "type": "string" }, "arguments": {} } } } }
        ]
      },
      "DecisionResponse": {
        "type": "object",
        "required": ["schemaVersion", "decision", "reasons", "findings", "classifier", "receipt", "tripwires"],
        "properties": {
          "schemaVersion": { "const": "szl.immune.decision/v1" },
          "decision": { "type": "string", "enum": ["ALLOW", "REVIEW", "DENY", "UNAVAILABLE"] },
          "reasons": { "type": "array", "items": { "type": "string" } },
          "findings": { "type": "array", "items": { "type": "object" } },
          "classifier": { "$ref": "#/components/schemas/ClassifierStatus" },
          "receipt": { "type": "object" },
          "tripwires": { "type": "array", "items": { "$ref": "#/components/schemas/Tripwire" } }
        }
      },
      "StatusResponse": {
        "type": "object",
        "required": ["schemaVersion", "service", "policy", "classifier", "signer", "capabilities"],
        "properties": {
          "schemaVersion": { "const": "szl.immune.status/v1" },
          "service": { "type": "object" },
          "policy": { "type": "object" },
          "classifier": { "$ref": "#/components/schemas/ClassifierStatus" },
          "signer": { "type": "object" },
          "capabilities": { "type": "object" }
        }
      },
      "ClassifierStatus": {
        "type": "object",
        "required": ["state", "modelId", "revision", "weightsSha256", "runtime", "device", "reasons"],
        "properties": {
          "state": { "type": "string", "enum": ["UNAVAILABLE", "THIRD_PARTY_BASELINE", "SZL_TRAINED_CANDIDATE", "QUALIFIED"] },
          "modelId": { "type": ["string", "null"] },
          "revision": { "type": ["string", "null"] },
          "weightsSha256": { "type": ["string", "null"] },
          "runtime": { "type": ["string", "null"] },
          "device": { "type": ["string", "null"] },
          "reasons": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Tripwire": {
        "type": "object",
        "required": ["id", "name", "implementationStatus", "evaluationState", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "implementationStatus": { "type": "string", "enum": ["IMPLEMENTED", "NOT_IMPLEMENTED"] },
          "evaluationState": { "type": "string", "enum": ["FIRED", "CLEAR", "NOT_EVALUATED"] },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      },
      "SessionState": {
        "type": "object",
        "required": ["schemaVersion", "sessionId", "strictMode", "requestCount", "windowStartedAt", "windowExpiresAt", "expiresAt"],
        "properties": {
          "schemaVersion": { "const": "szl.immune.session/v1" },
          "sessionId": { "type": "string" },
          "strictMode": { "type": "boolean" },
          "requestCount": { "type": "integer", "minimum": 0 },
          "windowStartedAt": { "type": "string", "format": "date-time" },
          "windowExpiresAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      },
      "ReceiptResponse": {
        "type": "object",
        "required": ["schemaVersion", "receiptId", "envelope", "payload", "chain"],
        "properties": {
          "schemaVersion": { "const": "szl.immune.receipt-response/v1" },
          "receiptId": { "type": "string" },
          "envelope": { "type": "object" },
          "payload": { "type": "object" },
          "chain": { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "message"],
        "properties": { "error": { "type": "string" }, "message": { "type": "string" } }
      }
    }
  }
}
