# wayra_snapshot.json — arXiv paper snapshot; abstracts are third-party academic
# prose quoted verbatim from arXiv. Hits on "premier", "state-of-the-art",
# "leading" are in academic abstracts, not SZL-authored claims.
wayra_snapshot.json

# web/src/data/ — SPA data files use "leading indicator" in the financial/
# econometric sense (cap-rate leading indicators, market micro-structure signals).
# These are technical domain terms, not marketing superlatives.
web/src/data/

# web/src/data/releases.ts — changelog entries document which terms were ADDED
# to the banned list; mentioning "seamless" in "Added 'seamless' to banned terms"
# is referential, not a marketing claim.
web/src/data/releases.ts
