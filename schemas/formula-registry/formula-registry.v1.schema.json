{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a11oy.net/schemas/formula-registry/formula-registry.v1.schema.json",
  "title": "SZL Dispute-Relevant Formula Maturity Crosswalk v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_digest", "signature", "payload"],
  "properties": {
    "schema_version": {"const": "szl.formula-registry.v1"},
    "registry_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "canonicalization", "scope", "value"],
      "properties": {
        "algorithm": {"const": "sha256"},
        "canonicalization": {"type": "string", "minLength": 20},
        "scope": {"const": "payload"},
        "value": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"const": "UNSIGNED"},
        "reason": {"type": "string", "minLength": 20}
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_version", "doctrine_version", "coverage_scope", "exhaustive",
        "covered_formula_ids", "source_repository", "locked_kernel_commit_prefix",
        "experimental_scope_commit_prefix", "locked_proven_count", "locked_proven_ids",
        "lambda_status", "policy", "source_assets", "formulas"
      ],
      "properties": {
        "registry_version": {"const": "1.0.0"},
        "doctrine_version": {"const": "v11"},
        "coverage_scope": {"type": "string", "minLength": 80},
        "exhaustive": {"const": false},
        "covered_formula_ids": {"const": ["F1", "F4", "F7", "F11", "F12", "F18", "F19", "F22", "F23"]},
        "source_repository": {"const": "https://github.com/szl-holdings/lutar-lean"},
        "locked_kernel_commit_prefix": {"type": "string", "pattern": "^[0-9a-f]{8}$"},
        "experimental_scope_commit_prefix": {"type": "string", "pattern": "^[0-9a-f]{8}$"},
        "locked_proven_count": {"const": 5},
        "locked_proven_ids": {"const": ["F1", "F11", "F12", "F18", "F19"]},
        "lambda_status": {"const": "CONJECTURE_1_ADVISORY"},
        "policy": {"$ref": "#/$defs/policy"},
        "source_assets": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/sourceAsset"}, {"properties": {"path": {"const": "corpus/formulas/lutar-lean__PROVEN_FORMULAS.md"}, "role": {"const": "authoritative maturity and locked-set report"}, "sha256": {"const": "9692d973c443fb46fa9031a92bf1f6587d5a03ab0abf1e62feec6fce7b01b8d9"}}}]},
            {"allOf": [{"$ref": "#/$defs/sourceAsset"}, {"properties": {"path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "role": {"const": "local Lean theorem source snapshot"}, "sha256": {"const": "0a7ea54762a96b335d3e6e082835542dbd0a22c1ea08db8d7315f77adb1dd8ea"}}}]},
            {"allOf": [{"$ref": "#/$defs/sourceAsset"}, {"properties": {"path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/ProvedFormulas.lean"}, "role": {"const": "local compact Lean theorem source snapshot"}, "sha256": {"const": "847d2e332017a5bfe3e7823092acf0245840f6b20f3d6f1544f723fd1607612e"}}}]},
            {"allOf": [{"$ref": "#/$defs/sourceAsset"}, {"properties": {"path": {"const": "proofs/lutar-lean/Lutar/Round13/Lambda_Uniqueness.lean"}, "role": {"const": "Lambda conditional results and unconditional counterexample source"}, "sha256": {"const": "ea7667f8c20deb469396d822273ede4577e53d5ce0f273dee590a4928b617525"}}}]}
          ],
          "items": false
        },
        "formulas": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F1"}, "maturity": {"const": "LOCKED_PROVEN"}, "locked_proven": {"const": true}, "theorem_refs": {"const": ["f1_replay_hash_determinism", "f1_replay_trace_stable"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "LEAN_CORE_ONLY"}, "evidence_status": {"const": "LOCKED_KERNEL_REPORT_AND_SOURCE_PRESENT"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F4"}, "maturity": {"const": "EXPERIMENTAL"}, "locked_proven": {"const": false}, "theorem_refs": {"const": ["f4_khipu_no_self_loop", "f4_khipu_acyclic_irrefl", "f4_khipu_reach_strictly_smaller", "f4_khipu_dag_acyclic"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "NOT_REEVALUATED_BY_THIS_REGISTRY"}, "evidence_status": {"const": "SOURCE_PRESENT_EXPERIMENTAL_NOT_LOCKED"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F7"}, "maturity": {"const": "EXPERIMENTAL"}, "locked_proven": {"const": false}, "theorem_refs": {"const": ["f7_chaski_enqueue_preserves_prefix", "f7_chaski_head_is_oldest", "f7_chaski_fifo", "f7_chaski_take_drop_roundtrip"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "NOT_REEVALUATED_BY_THIS_REGISTRY"}, "evidence_status": {"const": "SOURCE_PRESENT_EXPERIMENTAL_NOT_LOCKED"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F11"}, "maturity": {"const": "LOCKED_PROVEN"}, "locked_proven": {"const": true}, "theorem_refs": {"const": ["f11_ayni_reciprocity_conservation", "f11_tit_for_tat_parity"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "LEAN_CORE_ONLY"}, "evidence_status": {"const": "LOCKED_KERNEL_REPORT_AND_SOURCE_PRESENT"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F12"}, "maturity": {"const": "LOCKED_PROVEN_LIMITED_FRAGMENT"}, "locked_proven": {"const": true}, "theorem_refs": {"const": ["f12_kuramoto_additive"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "LEAN_CORE_ONLY"}, "evidence_status": {"const": "LOCKED_KERNEL_REPORT_AND_SOURCE_PRESENT"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F18"}, "maturity": {"const": "LOCKED_PROVEN"}, "locked_proven": {"const": true}, "theorem_refs": {"const": ["f18_reed_solomon_parity_count", "f18_erasure_tolerance"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "LEAN_CORE_ONLY"}, "evidence_status": {"const": "LOCKED_KERNEL_REPORT_AND_SOURCE_PRESENT"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F19"}, "maturity": {"const": "LOCKED_PROVEN_LIMITED_FRAGMENT"}, "locked_proven": {"const": true}, "theorem_refs": {"const": ["f19_bekenstein_additive", "f19_budget_monotone"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "LEAN_CORE_ONLY"}, "evidence_status": {"const": "LOCKED_KERNEL_REPORT_AND_SOURCE_PRESENT"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F22"}, "maturity": {"const": "EXPERIMENTAL"}, "locked_proven": {"const": false}, "theorem_refs": {"const": ["f22_emit_appends_length", "f22_emit_strictly_greater", "f22_khipu_emit_monotone"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Puriq/Formulas/PuriqFormulaLean.lean"}, "axiom_status": {"const": "NOT_REEVALUATED_BY_THIS_REGISTRY"}, "evidence_status": {"const": "SOURCE_PRESENT_EXPERIMENTAL_NOT_LOCKED"}}}]},
            {"allOf": [{"$ref": "#/$defs/formula"}, {"properties": {"id": {"const": "F23"}, "maturity": {"const": "CONJECTURE_1_ADVISORY"}, "locked_proven": {"const": false}, "theorem_refs": {"const": ["lambda_unique_of_factors", "maxAgg_ne_Lambda"]}, "source_path": {"const": "proofs/lutar-lean/Lutar/Round13/Lambda_Uniqueness.lean"}, "axiom_status": {"const": "CONDITIONAL_RESULTS_ONLY"}, "evidence_status": {"const": "UNCONDITIONAL_CLAIM_REFUTED_BY_COUNTEREXAMPLE"}}}]}
          ],
          "items": false
        }
      }
    }
  },
  "$defs": {
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locked_set_rule", "experimental_rule", "lambda_rule", "signing_rule"],
      "properties": {
        "locked_set_rule": {"type": "string", "minLength": 20},
        "experimental_rule": {"type": "string", "minLength": 20},
        "lambda_rule": {"type": "string", "minLength": 20},
        "signing_rule": {"type": "string", "minLength": 20}
      }
    },
    "sourceAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 3},
        "role": {"type": "string", "minLength": 10},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "formula": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "maturity", "locked_proven", "theorem_refs", "source_path", "axiom_status", "evidence_status"],
      "properties": {
        "id": {"type": "string", "pattern": "^F(?:[1-9]|1[0-9]|2[0-3])$"},
        "name": {"type": "string", "minLength": 3},
        "maturity": {"enum": ["LOCKED_PROVEN", "LOCKED_PROVEN_LIMITED_FRAGMENT", "EXPERIMENTAL", "CONJECTURE_1_ADVISORY"]},
        "locked_proven": {"type": "boolean"},
        "theorem_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
        "source_path": {"type": "string", "minLength": 3},
        "axiom_status": {"enum": ["LEAN_CORE_ONLY", "NOT_REEVALUATED_BY_THIS_REGISTRY", "CONDITIONAL_RESULTS_ONLY"]},
        "evidence_status": {"enum": ["LOCKED_KERNEL_REPORT_AND_SOURCE_PRESENT", "SOURCE_PRESENT_EXPERIMENTAL_NOT_LOCKED", "UNCONDITIONAL_CLAIM_REFUTED_BY_COUNTEREXAMPLE"]},
        "caveat": {"type": "string", "minLength": 20}
      }
    }
  }
}
