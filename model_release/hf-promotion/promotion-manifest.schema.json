{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a-11-oy.com/schemas/szl-hf-promotion-manifest-v1.json",
  "title": "SZL offline Hugging Face promotion guard",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "manifest_id", "as_of", "mode", "network_access_allowed", "credential_access_allowed", "automatic_upload_allowed", "canonical_authority", "bucket_authority", "topology_contract", "candidates", "global_release_predicate", "forbidden_file_extensions", "external_mutations"],
  "properties": {
    "$schema": {"const": "./promotion-manifest.schema.json"},
    "schema_version": {"const": "szl.hf-promotion-manifest.v1"},
    "manifest_id": {"const": "SZL-HF-Promotion-Guard-v1"},
    "as_of": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"},
    "mode": {"const": "OFFLINE_AUDIT_ONLY"},
    "network_access_allowed": {"const": false},
    "credential_access_allowed": {"const": false},
    "automatic_upload_allowed": {"const": false},
    "canonical_authority": {"const": "VERSIONED_HUGGING_FACE_REPOSITORY_PLUS_SIGNED_RELEASE_RECEIPT"},
    "bucket_authority": {"const": "MUTABLE_NONCANONICAL_STAGING_ONLY"},
    "topology_contract": {"const": "model_release/szl-hf-bucket-topology.json"},
    "candidates": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/candidate"}
    },
    "global_release_predicate": {"type": "array", "minItems": 6, "items": {"type": "string", "minLength": 20}},
    "forbidden_file_extensions": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"type": "string", "pattern": "^\\.[a-z0-9]+$"}},
    "external_mutations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket_objects_uploaded", "model_or_dataset_repository_created", "weights_or_adapter_published", "space_deployed", "collection_created", "promotion_performed"],
      "properties": {
        "bucket_objects_uploaded": {"const": false},
        "model_or_dataset_repository_created": {"const": false},
        "weights_or_adapter_published": {"const": false},
        "space_deployed": {"const": false},
        "collection_created": {"const": false},
        "promotion_performed": {"const": false}
      }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "candidate_slug", "artifact_class", "canonical_target", "target_kind", "target_state", "promotion_decision", "allowed_public_payload_classes", "forbidden_public_payload_classes", "bucket_prefixes", "model_card_truth", "local_artifacts", "qualification_gates"],
      "properties": {
        "candidate_id": {"type": "string", "minLength": 8},
        "candidate_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "artifact_class": {"enum": ["CONFIGURATION_RECIPE", "PEFT_ADAPTER", "DATASET"]},
        "canonical_target": {"type": "string", "pattern": "^SZLHOLDINGS/[A-Za-z0-9._-]+$"},
        "target_kind": {"enum": ["MODEL", "DATASET"]},
        "target_state": {"type": "string", "minLength": 5},
        "promotion_decision": {"type": "string", "pattern": "^BLOCKED_"},
        "allowed_public_payload_classes": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
        "forbidden_public_payload_classes": {"type": "array", "minItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
        "bucket_prefixes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["build", "evaluation", "runtime"],
          "properties": {
            "build": {"type": "string", "pattern": "^attempts/\\{attempt_id\\}/payload/[a-z0-9-]+/$"},
            "evaluation": {"type": "string", "pattern": "^attempts/\\{attempt_id\\}/payload/[a-z0-9-]+/$"},
            "runtime": {"type": "string", "pattern": "^batches/\\{attempt_id\\}/payload/[a-z0-9-]+/$"}
          }
        },
        "model_card_truth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "required_literals", "forbidden_case_insensitive_literals"],
          "properties": {
            "path": {"type": "string", "pattern": "^model_release/.+/MODEL_CARD(?:_[A-Z_]+)?_DRAFT\\.md$"},
            "required_literals": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 4}},
            "forbidden_case_insensitive_literals": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string", "minLength": 4}}
          }
        },
        "local_artifacts": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/localArtifact"}
        },
        "qualification_gates": {
          "type": "array",
          "minItems": 6,
          "items": {"$ref": "#/$defs/gate"}
        }
      }
    },
    "localArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256", "role"],
      "properties": {
        "path": {"type": "string", "pattern": "^(model_release|attestations)/[A-Za-z0-9._/-]+$"},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "role": {"type": "string", "minLength": 4}
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "name", "state", "blocking", "evidence"],
      "properties": {
        "gate_id": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
        "name": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "state": {"enum": ["PASS", "BLOCKED", "ABSENT", "NOT_RUN", "FAIL"]},
        "blocking": {"const": true},
        "evidence": {"type": "string", "minLength": 20}
      }
    }
  }
}
