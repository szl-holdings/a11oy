{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a-11-oy.com/schemas/brain-row-provenance-license-crosswalk-receipt.v1.json",
  "title": "Brain row provenance/license crosswalk receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation",
    "repository",
    "inputs",
    "output",
    "coverage",
    "blocker_counts",
    "authorization",
    "non_claims",
    "receipt_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "szl.brain-row-provenance-license-crosswalk-receipt.v1"
    },
    "operation": {"const": "EVIDENCE_CROSSWALK_NOT_ADMISSION"},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "revision"],
      "properties": {
        "uri": {"const": "https://github.com/szl-holdings/a11oy"},
        "revision": {"type": "string", "pattern": "^git:[0-9a-f]{40}$"}
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger", "snapshot", "license"],
      "properties": {
        "ledger": {"$ref": "#/$defs/inputRows"},
        "snapshot": {"$ref": "#/$defs/input"},
        "license": {"$ref": "#/$defs/input"}
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "rows", "content_policy"],
      "properties": {
        "path": {"const": "brain-row-provenance-license-crosswalk.v1.jsonl"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "rows": {"type": "integer", "minimum": 1, "maximum": 9464},
        "content_policy": {"const": "OPAQUE_ROW_KEY_AND_EVIDENCE_STATES_ONLY"}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "immutable_ledger_binding_pass",
        "immutable_item_origin_pass",
        "version_bound_license_pass",
        "signed_privacy_clearance_pass",
        "semantic_duplication_evidence_pass",
        "signed_consent_or_permission_pass",
        "signed_independent_review_pass",
        "admitted_rows",
        "quarantined_rows"
      ],
      "properties": {
        "immutable_ledger_binding_pass": {"type": "integer", "minimum": 0, "maximum": 9464},
        "immutable_item_origin_pass": {"const": 0},
        "version_bound_license_pass": {"type": "integer", "minimum": 0, "maximum": 9464},
        "signed_privacy_clearance_pass": {"const": 0},
        "semantic_duplication_evidence_pass": {"const": 0},
        "signed_consent_or_permission_pass": {"const": 0},
        "signed_independent_review_pass": {"const": 0},
        "admitted_rows": {"const": 0},
        "quarantined_rows": {"type": "integer", "minimum": 1, "maximum": 9464}
      }
    },
    "blocker_counts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "integer", "minimum": 1, "maximum": 9464}
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature_state",
        "training_authorized",
        "training_triggered",
        "model_promotion_allowed"
      ],
      "properties": {
        "signature_state": {"const": "UNSIGNED_NO_APPROVED_KEY"},
        "training_authorized": {"const": false},
        "training_triggered": {"const": false},
        "model_promotion_allowed": {"const": false}
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 3, "maxLength": 128}
    },
    "receipt_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "git_blob_verified"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 256},
        "sha256": {"$ref": "#/$defs/sha256"},
        "git_blob_verified": {"type": "boolean"}
      }
    },
    "inputRows": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "rows", "git_blob_verified"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 256},
        "sha256": {"$ref": "#/$defs/sha256"},
        "rows": {"type": "integer", "minimum": 1, "maximum": 9464},
        "git_blob_verified": {"type": "boolean"}
      }
    }
  }
}
