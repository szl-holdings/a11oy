{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a-11-oy.com/schemas/szl.brain-training-candidate.v2.json",
  "title": "SZL Brain row training candidate v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "node_id",
    "content",
    "content_sha256",
    "source",
    "rights",
    "privacy",
    "contamination",
    "review",
    "split"
  ],
  "properties": {
    "schema_version": {"const": "szl.brain-training-candidate.v2"},
    "node_id": {"type": "string", "minLength": 3, "maxLength": 256},
    "content": {"type": "string", "minLength": 1, "maxLength": 65536},
    "content_sha256": {"$ref": "#/$defs/sha256"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "uri", "revision", "timestamp_utc", "evidence"],
      "properties": {
        "identity": {"type": "string", "minLength": 3, "maxLength": 256},
        "uri": {"type": "string", "minLength": 3, "maxLength": 2048},
        "revision": {"type": "string", "pattern": "^(git:[0-9a-f]{40,64}|sha256:[0-9a-f]{64})$"},
        "timestamp_utc": {"type": "string", "format": "date-time"},
        "evidence": {"$ref": "#/$defs/evidenceDescriptor"}
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "rightsholder", "basis", "license", "permission_scope", "evidence"],
      "properties": {
        "author": {"type": "string", "minLength": 3, "maxLength": 256},
        "rightsholder": {"type": "string", "minLength": 3, "maxLength": 256},
        "basis": {"type": "string", "minLength": 3, "maxLength": 128},
        "license": {"type": "string", "minLength": 1, "maxLength": 128},
        "permission_scope": {"type": "string", "minLength": 3, "maxLength": 128},
        "evidence": {"$ref": "#/$defs/evidenceDescriptor"}
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "pii_result", "method", "evidence"],
      "properties": {
        "classification": {"type": "string", "minLength": 3, "maxLength": 64},
        "pii_result": {"enum": ["CLEAR", "DETECTED", "UNKNOWN"]},
        "method": {"type": "string", "minLength": 3, "maxLength": 128},
        "evidence": {"$ref": "#/$defs/evidenceDescriptor"}
      }
    },
    "contamination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "method", "checked_against", "evidence"],
      "properties": {
        "result": {"enum": ["CLEAR", "DETECTED", "UNKNOWN"]},
        "method": {"type": "string", "minLength": 3, "maxLength": 128},
        "checked_against": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 2, "maxLength": 256}
        },
        "evidence": {"$ref": "#/$defs/evidenceDescriptor"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reviewer", "reviewed_at_utc", "reasons", "evidence"],
      "properties": {
        "state": {"enum": ["APPROVED", "REJECTED", "NEEDS_REVIEW"]},
        "reviewer": {"type": "string", "minLength": 3, "maxLength": 256},
        "reviewed_at_utc": {"type": "string", "format": "date-time"},
        "reasons": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 3, "maxLength": 128}
        },
        "evidence": {"$ref": "#/$defs/evidenceDescriptor"}
      }
    },
    "split": {"enum": ["TRAIN", "EVAL"]}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidenceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 4096},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
