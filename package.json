{
  "name": "workspace",
  "version": "1.1.0",
  "private": true,
  "description": "A11oy governed-AI execution fabric — Apache-2.0, signed receipts, fail-closed evidence states, sovereign/self-hosted inference, and formal-artifact lineage.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "jest __tests__/",
    "test:knowledge": "cd packages/a11oy-knowledge && npm test",
    "test:knowledge:lookup": "tsx packages/a11oy-knowledge/src/theorems_lookup.test.ts",
    "test:qec": "tsx packages/qec-integrity/src/qec_lineage.test.ts",
    "test:policy-gates": "tsx packages/policy/src/gates/__tests__/policy_gates.test.ts",
    "test:core": "cd web/packages/a11oy-core && npx vitest run",
    "test:all": "npm test && npm run test:knowledge && npm run test:qec && npm run test:core",
    "build:doctrine": "pnpm --dir web/packages/a11oy-connection run build && pnpm --dir web/packages/a11oy-core run build",
    "test:doctrine": "pnpm --dir web/packages/a11oy-core run test:doctrine",
    "typecheck:doctrine": "pnpm --dir web/packages/a11oy-connection run build && pnpm --dir web/packages/a11oy-connection run typecheck && pnpm --dir web/packages/a11oy-core run typecheck",
    "payload:manifest": "python3 scripts/payload_manifest.py deploy --output deploy/MANIFEST.json",
    "payload:verify": "python3 scripts/payload_manifest.py deploy --output deploy/MANIFEST.json --verify",
    "payload:huggingface": "python3 scripts/prepare_huggingface_payload.py",
    "payload:bundle": "pnpm build:doctrine && pnpm payload:manifest && pnpm payload:huggingface && python3 scripts/build_operational_payload.py",
    "payload:bundle:verify": "python3 scripts/build_operational_payload.py --verify",
    "ecosystem:audit": "python3 scripts/ecosystem_audit.py",
    "ecosystem:readiness": "python3 scripts/build_ecosystem_readiness.py --check",
    "ecosystem:readiness:write": "python3 scripts/build_ecosystem_readiness.py",
    "payload:publish:huggingface": "python3 scripts/publish_huggingface_payload.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szl-holdings/a11oy.git"
  },
  "keywords": [],
  "author": "Stephen P. Lutar Jr. <contact@szlholdings.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/szl-holdings/a11oy/issues"
  },
  "homepage": "https://a-11-oy.com",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.2",
      "esbuild": "0.28.1",
      "js-yaml@<4.2.0": "4.2.0"
    }
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "4.2.0"
    }
  }
}
