{
  "name": "workspace",
  "version": "1.0.0",
  "description": "[![License](https://img.shields.io/badge/License-Proprietary-0B1F3A.svg?style=flat-square)](./LICENSE) [![DOI](https://zenodo.org/badge/DOI/10.5281/zenodo.20434276.svg)](https://doi.org/10.5281/zenodo.20434276) [![CI](https://github.com/szl-holdings/a11oy/actions/workflows/ci.yml/badge.svg?branch=main)](https://github.com/szl-holdings/a11oy/actions/workflows/ci.yml) [![CodeQL](https://github.com/szl-holdings/a11oy/actions/workflows/codeql.yml/badge.svg?branch=main)](https://github.com/szl-holdings/a11oy/actions/workflows/codeql.yml) [![SBOM](https://github.com/szl-holdings/a11oy/actions/workflows/sbom.yml/badge.svg?branch=main)](https://github.com/szl-holdings/a11oy/actions/workflows/sbom.yml) [![SLSA L1](https://img.shields.io/badge/SLSA-L1_(SBOM_%2B_DCO)-0B1F3A.svg?style=flat-square)](https://github.com/szl-holdings/a11oy/actions/workflows/slsa.yml) [![MCP Compatible](https://img.shields.io/badge/MCP-compatible-0B1F3A.svg?style=flat-square&logoColor=00D4FF)](https://modelcontextprotocol.io) [![DCO](https://github.com/szl-holdings/a11oy/actions/workflows/dco.yml/badge.svg?branch=main)](https://github.com/szl-holdings/a11oy/actions/workflows/dco.yml) [![ORCID](https://img.shields.io/badge/ORCID-0009--0001--0110--4173-A6CE39.svg?style=flat-square&logo=orcid&logoColor=white)](https://orcid.org/0009-0001-0110-4173)",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "jest __tests__/",
    "test:knowledge": "cd packages/a11oy-knowledge && npm test",
    "test:knowledge:lookup": "tsx packages/a11oy-knowledge/src/theorems_lookup.test.ts",
    "test:qec": "tsx packages/qec-integrity/src/qec_lineage.test.ts",
    "test:policy-gates": "tsx packages/policy/src/gates/__tests__/policy_gates.test.ts",
    "test:core": "cd web/packages/a11oy-core && npx vitest run",
    "test:all": "npm test && npm run test:knowledge && npm run test:qec && npm run test:core",
    "build:doctrine": "pnpm --dir web/packages/a11oy-connection run build && pnpm --dir web/packages/a11oy-core run build",
    "test:doctrine": "pnpm --dir web/packages/a11oy-core run test:doctrine",
    "typecheck:doctrine": "pnpm --dir web/packages/a11oy-connection run build && pnpm --dir web/packages/a11oy-connection run typecheck && pnpm --dir web/packages/a11oy-core run typecheck",
    "payload:manifest": "python3 scripts/payload_manifest.py deploy --output deploy/MANIFEST.json",
    "payload:verify": "python3 scripts/payload_manifest.py deploy --output deploy/MANIFEST.json --verify",
    "payload:huggingface": "python3 scripts/prepare_huggingface_payload.py",
    "payload:bundle": "pnpm build:doctrine && pnpm payload:manifest && pnpm payload:huggingface && python3 scripts/build_operational_payload.py",
    "payload:bundle:verify": "python3 scripts/build_operational_payload.py --verify",
    "ecosystem:audit": "python3 scripts/ecosystem_audit.py",
    "ecosystem:readiness": "python3 scripts/build_ecosystem_readiness.py --check",
    "ecosystem:readiness:write": "python3 scripts/build_ecosystem_readiness.py",
    "payload:publish:huggingface": "python3 scripts/publish_huggingface_payload.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szl-holdings/a11oy.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/szl-holdings/a11oy/issues"
  },
  "homepage": "https://github.com/szl-holdings/a11oy#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.2",
      "esbuild": "0.28.1",
      "js-yaml@<4.2.0": "4.2.0"
    }
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "4.2.0"
    }
  }
}
