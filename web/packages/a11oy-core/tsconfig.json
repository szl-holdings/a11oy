{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "noEmit": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@a11oy/connection": [
        "../a11oy-connection/dist/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/pesher_renderer.ts",
    "src/**/__tests__/**/*.ts"
  ]
}
